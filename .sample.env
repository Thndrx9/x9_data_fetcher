# OpenAlgo API key for x9_data_fetcher
API_KEY=''

# OpenAlgo HTTP host (for reference)
OPENALGO_HOST='http://127.0.0.1:5000'

# WebSocket endpoint used by x9_data_fetcher
WEBSOCKET_HOST='127.0.0.1'
WEBSOCKET_PORT='8765'
# Optional full URL override:
# WEBSOCKET_URL='ws://127.0.0.1:8765'

# Input symbols and output locations
X9_FETCHER_SYMBOLS_CSV='x9_data_fetcher/symbols.csv'
X9_DEPTH_OUTPUT_DIR='data'
X9_QUOTE_OUTPUT_DIR='data'
X9_OHLC_OUTPUT_DIR='data'

# Optional tuning
X9_DEPTH_LEVELS='5'
X9_DEPTH_FLUSH_BATCH='200'
X9_DEPTH_FLUSH_INTERVAL_SEC='1.0'
X9_FETCHER_VENV_DIR='x9_data_fetcher/executor'
